{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Duewise: debug Next.js",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:debug"],
      "cwd": "${workspaceFolder}",
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"],
      "serverReadyAction": {
        "pattern": "- Local:\\s+(https?://localhost:\\d+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      },
      "envFile": "${workspaceFolder}/.env.local",
      "console": "integratedTerminal",
      "autoAttachChildProcesses": true
    },
    {
      "name": "Duewise: attach server",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"]
    },
    {
      "name": "Duewise: debug browser",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Duewise: full stack",
      "configurations": ["Duewise: debug Next.js", "Duewise: debug browser"],
      "stopAll": true
    }
  ]
}
