{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Duewise: dev debug",
      "type": "npm",
      "script": "dev:debug",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "owner": "next",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting",
          "endsPattern": "Ready in"
        }
      }
    },
    {
      "label": "Duewise: typecheck",
      "type": "npm",
      "script": "typecheck",
      "group": "test",
      "problemMatcher": "$tsc"
    }
  ]
}
