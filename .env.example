NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=

# Optional: use a dedicated Google Cloud Storage bucket for Duewise uploads.
# If unset, uploads fall back to FIREBASE_STORAGE_BUCKET / NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET.
# The Firebase Admin service account above must have Storage Object permissions on this bucket.
GCP_STORAGE_BUCKET=your-gcp-bucket-name
# Optional TTL for signed upload URLs, in seconds.
GCP_SIGNED_URL_TTL_SECONDS=900

# Admin console (local username/password). Leave unset to disable /admin entirely.
ADMIN_USERNAME=admin@duewise.com
ADMIN_PASSWORD=change-me-to-a-strong-password
# 32+ random chars used to sign the admin session cookie, e.g. `openssl rand -base64 48`
ADMIN_SESSION_SECRET=4l2Qk6Lvg9+NceeKNxhPSbJTil0jxupNccsKSpZjXe3IIPRx+DBs6b6w1wG4Dq0O
