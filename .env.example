NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Firebase Console > Project settings > Cloud Messaging > Web Push certificates.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=BPbZrXGCUmTfZKnTC0RViuYCsr7-6qSZstDHutT0pyVTqFUOfpWH8vQAbXNxjE7thM9rAYGNrDfcbphwKvafcoU

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=

# Optional: use a dedicated Google Cloud Storage bucket for Duewise uploads.
# If unset, uploads fall back to FIREBASE_STORAGE_BUCKET / NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET.
# The Firebase Admin service account above must have Storage Object permissions on this bucket.
GCP_STORAGE_BUCKET=your-gcp-bucket-name
# Optional TTL for signed upload URLs, in seconds.
GCP_SIGNED_URL_TTL_SECONDS=900

# 32+ random chars used to sign the app-level authenticator MFA browser session.
DUEWISE_MFA_SESSION_SECRET=change-me-to-a-long-random-secret

# Shared secret for cron-job.org to call /api/cron/notifications.
CRON_SECRET=change-me-to-a-long-random-secret

# Optional: Redis URL for caching family members, documents, and other relations.
# Get from Upstash Redis: https://console.upstash.com
# Format: redis://default:PASSWORD@HOST:PORT
REDIS_URL=

# Enable/disable Redis caching (requires REDIS_URL to be set).
# Set to "true" to enable caching; "false" or unset to disable.
# When disabled, app uses Firestore directly (slower but works fine for small households).
# Reduces Firestore reads by ~80% and improves load times 10-100x.
# Recommended for 100+ households; skip for development/small deployments.
ENABLE_REDIS=false
